@using ControleDeMedicamentosWeb.WebApp.Modulos.ModuloPaciente.Apresentacao

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Edição de Paciente";
}

@model EditarPacienteViewModel

<form asp-action="Editar" method="post">

    <input asp-for="Id" type="hidden" />

    <div class="mb-3">
        <label asp-for="Nome" class="form-label"></label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Telefone" class="form-label"></label>
        <input asp-for="Telefone" class="form-control" />
        <span asp-validation-for="Telefone" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CartaoSUS" class="form-label"></label>
        <input asp-for="CartaoSUS" class="form-control" />
        <span asp-validation-for="CartaoSUS" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Cpf" class="form-label"></label>
        <input asp-for="Cpf" class="form-control" />
        <span asp-validation-for="Cpf" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            Confirmar
        </button>

        <a asp-action="Listar" class="btn btn-secondary">
            Voltar
        </a>
    </div>

</form>