@{
    Layout = "_Layout";
    ViewBag.Titulo = "Cadastro de Medicamento";
}

@model CadastrarMedicamentoViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Cadastrar" method="post">
    <div class="mb-3">
        <label asp-for="Nome" class="form-label fw-semibold text-primary text-uppercase small">Nome</label>
        <input asp-for="Nome" type="text" class="form-control">
        <span asp-validation-for="Nome" class="text-danger small fw-semibold"></span>
    </div>
    
    <div class="mb-3">
        <label asp-for="Descricao" class="form-label fw-semibold text-primary text-uppercase small">Descrição</label>
        <input asp-for="Descricao" type="text" class="form-control">
        <span asp-validation-for="Descricao" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Quantidade" class="form-label fw-semibold text-primary text-uppercase small">Quantidade em Estoque</label>
        <input asp-for="Quantidade" type="text" class="form-control">
        <span asp-validation-for="Quantidade" class="text-danger small fw-semibold"></span>
    </div>  

    <div class="mb-3">
        <label asp-for="FornecedorNome" class="form-label fw-semibold text-primary text-uppercase small">Fornecedor</label>
        <select asp-for="FornecedorNome" asp-items="ViewBag.Fornecedores" class="form-select">
            <option value="">Selecione um fornecedor...</option>
        </select>
        <span asp-validation-for="FornecedorNome" class="text-danger small fw-semibold"></span>
    </div>   

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
    </div>
</form>
