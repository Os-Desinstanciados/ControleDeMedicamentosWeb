@using ControleDeMedicamentosWeb.WebApp.Modulos.ModuloFuncionario.Apresentacao

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Funcionários";
}

@model List<ListarFuncionarioViewModel>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Funcionários Cadastrados</h3>

    <a asp-action="Cadastrar" class="btn btn-primary">
        Cadastrar Novo
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">

        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Telefone</th>
                    <th>CPF</th>
                    <th width="180">Ações</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var funcionario in Model)
                {
                    <tr>
                        <td>@funcionario.Nome</td>
                        <td>@funcionario.Telefone</td>
                        <td>@funcionario.Cpf</td>

                        <td>
                            <a asp-action="Editar"
                               asp-route-id="@funcionario.Id"
                               class="btn btn-sm btn-warning">
                                Editar
                            </a>

                            <a asp-action="Excluir"
                               asp-route-id="@funcionario.Id"
                               class="btn btn-sm btn-danger">
                                Excluir
                            </a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>
</div>